const commentTexts = [
  'Absolutely love this! 😍', 'Great find, adding to my wishlist!', 'Where can I get one?',
  'This is stunning!', 'The quality looks amazing', 'Thanks for sharing! 🙌',
  'Perfect for my collection', 'Been looking for something like this', 'Incredible work!',
